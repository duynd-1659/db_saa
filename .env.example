#----------------------------------------------------------
# Supabase Local Development Environment Variables
#   Google OAuth (for local development)
#   Get these from https://console.cloud.google.com/apis/credentials
#----------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
SUPABASE_EXTRA_SEEDS=./seeds/dev/*.sql

#----------------------------------------------------------
# Client Environment Variables
#----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://project_id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Auth callback URL — for local dev use http://localhost:3000/api/auth/callback
NEXT_PUBLIC_AUTH_REDIRECT_URL=/api/auth/callback

#----------------------------------------------------------
# Server Environment Variables
#----------------------------------------------------------
SUPABASE_SECRET_KEY=your_supabase_secret_key

#----------------------------------------------------------
# Homepage — Event Configuration
#----------------------------------------------------------
# ISO-8601 fallback if app_config table has no event_start_datetime row
NEXT_PUBLIC_EVENT_START_DATETIME=2026-12-31T18:30:00+07:00
